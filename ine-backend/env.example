# ─────────────────────────────────────────────────────────────────
#  INE Guatemala — Canasta Básica API — Variables de entorno
#  Copia este archivo como .env y ajusta los valores
#  IMPORTANTE: nunca subas .env a GitHub
# ─────────────────────────────────────────────────────────────────

# Puerto del servidor (default: 3001)
PORT=3001

# Orígenes permitidos para CORS
# Desarrollo:  ALLOWED_ORIGINS=*
# Producción:  ALLOWED_ORIGINS=https://mi-dashboard.com
ALLOWED_ORIGINS=*

# ── OPENAI API KEY ────────────────────────────────────────────────
# Obtén tu key en: https://platform.openai.com/api-keys
# La key empieza con: sk-proj-...
# NUNCA la pongas en el frontend — solo aquí en el backend.
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXX

# ── TOKEN DE ADMINISTRADOR (opcional) ────────────────────────────
# Protege el endpoint /admin/refresh
# Si está vacío, el endpoint es público
ADMIN_TOKEN=
